alias shellconfig="nvim ~/dotfiles/shell/."
alias source_zsh="source ~/.zshrc"
alias vimconfig="nvim ~/.config/nvim/init.vim"
alias update="sudo apt update && sudo apt upgrade -y"
alias bu="brew upgrade"
alias vim="nvim"
