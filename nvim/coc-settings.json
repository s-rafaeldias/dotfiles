{
    // Python
    "python.jediEnabled": false,
    "python.condaPath": "~/miniconda3/bin/conda",
    "python.formatting.provider": "black",

    // Js
    "javascript.suggest.completeFunctionCalls": false,
    "typescript.suggest.completeFunctionCalls": false,
    "tsserver.formatOnType": true,
    "coc.preferences.formatOnSaveFiletypes": ["css", "Markdown", "javascriptreact", "javascript"],

    // Ruby
    "solargraph.commandPath": "/Users/rafael/.rbenv/shims/solargraph",

    // HTML
    "emmet.showAbbreviationSuggestions": false,
    "html.format.enable": true,

    "codeLens.enable": true, 
    "languageserver": {
        "golang": {
          "command": "gopls",
          "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
          "filetypes": ["go"]
        },
        "elixirLS": {
          "command": "~/.elixir/elixir-ls/rel/language_server.sh",
          "filetypes": ["elixir", "eelixir"]
        },
        "haskell": {
          "command": "hie-wrapper",
          "rootPatterns": [".stack.yaml", "cabal.config", "package.yaml"],
          "filetypes": ["hs", "lhs", "haskell"],
          "initializationOptions": {
            "languageServerHaskell": {}
          }
        },
        "elmLS": {
          "command": "elm-language-server",
          "filetypes": ["elm"],
          "rootPatterns": ["elm.json"],
          "trace.server": "verbose",
          "initializationOptions": {
            "elmPath": "elm",
            "elmFormatPath": "elm-format",
            "elmTestPath": "elm-test",
            "elmAnalyseTrigger": "change"
          }
        }
    }
}

